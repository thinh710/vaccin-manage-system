# Database Configuration
# Copy this file to .env and update with your values
# NEVER commit .env to git!

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres #user của mình
DB_PASSWORD=postgres #password của mình
DB_NAME=vaccin #tự tạo chay trong postgresql

# SSL Mode for PostgreSQL
# disable: no SSL (for local development)
# require: SSL required (for production)
DB_SSLMODE=disable

# Connection Pool Settings (Optional)
# Maximum number of open connections
DB_MAX_OPEN_CONNS=25

# Maximum number of idle connections
DB_MAX_IDLE_CONNS=5

# Maximum lifetime of a connection (in minutes)
DB_CONN_MAX_LIFETIME=5

# Application Configuration
# Server port
SERVER_PORT=8080

# Environment: development, staging, production
APP_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# 🎓 NOTES:
#
# 1. Environment Variables:
#    - Separate configuration from code
#    - Different values per environment
#    - 12-factor app principle
#
# 2. Security:
#    - Add .env to .gitignore
#    - Use .env.example as template
#    - Never hardcode secrets in source code
#
# 3. Docker vs Host:
#    - Host: DB_HOST=localhost
#    - Docker: DB_HOST=db (service name)
#
# 4. Connection Pool:
#    - Reuse database connections
#    - Improve performance
#    - Prevent connection exhaustion
#
# 5. Loading in Go:
#    import "github.com/joho/godotenv"
#    
#    godotenv.Load()
#    dbHost := os.Getenv("DB_HOST")
#
# 6. Production:
#    - Use environment variables directly (not .env file)
#    - Set in Kubernetes/Docker/Cloud Provider
#    - Use secret management (AWS Secrets Manager, Vault)
